{
  "name": "SQL Dev Environment",
  "dockerComposeFile": [
    "../containers/MS_SQL/docker-compose.yml",
    "../containers/caddy/docker-compose.caddy.yml",
    "docker-compose.extend.yml"
    ],

  "service": "dev-environment",
  "workspaceFolder": "/workspace",
  "forwardPorts": 
    [80, 5000, 5001, 5002, 5003, 5004, 5005],
  "settings": {
    "workbench.colorTheme": "Cobalt2"
  },

  "extensions": [
	"websos.theme-cobalt2",
	"ms-azuretools.vscode-docker",
	"dineug.vuerd-vscode",
	"randomfractalsinc.geo-data-viewer",
	"chris-rimmer.liquibase-snippets",
	"cweijan.vscode-postgresql-client2",
	"github.vscode-pull-request-github",
	"ms-vscode-remote.remote-wsl"
],

  "remoteUser": "root",
  "shutdownAction": "stopCompose"
}